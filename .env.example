# API keys for the virtual-biotech agent backends.
#
# Copy this file to `.env` and fill in the keys you have. The `.env` file is
# gitignored and never committed. The agent harness reads these from the
# environment (see skills/virtual-biotech-cso/runners.py).
#
# Backend selection order for `--backend auto`:
#   1. ANTHROPIC_API_KEY  (primary)
#   2. OPENAI_API_KEY
#   3. GEMINI_API_KEY / GOOGLE_API_KEY
#   4. Claude Code CLI (no key needed)

# --- Anthropic (primary) ---
ANTHROPIC_API_KEY=

# --- OpenAI-compatible (optional) ---
OPENAI_API_KEY=
# OPENAI_BASE_URL=

# --- Google Gemini (optional) ---
GEMINI_API_KEY=
# GOOGLE_API_KEY=

# --- Optional model override ---
# VBIO_MODEL=

# --- Prometheux (hosted Vadalog reasoning engine) ---
# When set, the live hosted engine runs the evidence-graph rules; unset falls
# back to the local in-process reasoner (no network, fully reproducible).
# Both vars are required for the live path: the SDK ships pointing at
# http://localhost:8000, so JARVISPY_URL must name your hosted org/user backend
# or every call 404s. The org/username are encoded in the token's JWT payload;
# the URL pattern is https://api.prometheux.ai/jarvispy/{org}/{username}.
# The live path also needs an active compute machine (start one in the
# Prometheux web app -> Compute Management) or run_concept returns NO_ACTIVE_COMPUTE.
PMTX_TOKEN=
# JARVISPY_URL=https://api.prometheux.ai/jarvispy/{org}/{username}

# --- Tavily (lit-synthesizer live web search; --demo needs no key) ---
TAVILY_API_KEY=

# --- Langfuse (optional tracing mirror; activates only when BOTH keys set) ---
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
# LANGFUSE_HOST=  # self-hosted Langfuse base URL; omit for Langfuse Cloud
